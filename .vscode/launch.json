    "version": "0.2.0",
    "configurations": [
        {
            "type": "chrome",
            "request": "launch",
            "name": "Chrome: lane-learn (localhost:3000)",
            "url": "http://localhost:3000",
            "webRoot": "${workspaceFolder}/lane-learn",
            "userDataDir": "${workspaceFolder}/.vscode/chrome-debug-profile"
