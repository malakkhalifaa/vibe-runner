        {
            "type": "msedge",
            "request": "launch",
            "name": "Edge: lane-learn (localhost:3000)",
            "url": "http://localhost:3000",
            "webRoot": "${workspaceFolder}/lane-learn",
            "userDataDir": "${workspaceFolder}/.vscode/edge-debug-profile"
        }
    ]
}
